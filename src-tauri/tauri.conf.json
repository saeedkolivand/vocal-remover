{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vocal-remover",
  "version": "1.0.0",
  "identifier": "com.vocalremover.local",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vocal Remover",
        "width": 1120,
        "height": 840,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/saeedkolivand/vocal-remover/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFREU1MTQ1NDU1MjU4OEIKUldTTFdGSkZSVkhlanMyaTgrOVM5QXNQVFZlU2lIZFF0ZGdnbXFsRXc1RVJNVlZOZlYvN1ZJaWwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../sidecar/vr-backend/": "backend/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
