sidecar/
build/
*.spec.bak

# assembled portable distributable (multi-GB)
release-portable/
dist-portable/
*.zip

# local tooling / editor / os
.impeccable/
.claude/settings.local.json
*.log
.DS_Store
Thumbs.db

